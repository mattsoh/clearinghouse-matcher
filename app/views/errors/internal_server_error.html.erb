<% content_for :title, "Something went wrong" %>

<div class="w-full max-w-lg mx-auto text-center">
  <h1 class="text-2xl font-semibold mb-4">Something went wrong</h1>
  <p class="text-gray-500 mb-4">An unexpected error occurred on our end. If you contact the engineering team, please give them this code so they can look up what happened:</p>

  <code class="inline-block px-4 py-2 rounded-lg bg-gray-100 text-gray-800 font-mono text-lg tracking-wide"><%= error_id %></code>

  <div class="mt-8">
    <%= link_to "Go back home", root_path, class: "inline-block px-4 py-2 rounded-lg bg-gray-800 text-white hover:bg-gray-700" %>
  </div>
</div>
